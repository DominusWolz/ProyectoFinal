<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.View.Inicio"
             Title="Inicio"
             BackgroundColor="#0F172A">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="30" Padding="30">

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0, 30, 0, 10">
                    <Label Text="PROYECTO FINAL" 
                           FontSize="36" 
                           FontAttributes="Bold" 
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <Label Text="Orientación inteligente con sensores" 
                           FontSize="18" 
                           TextColor="#94A3B8"
                           HorizontalOptions="Center" />

                    <Label Text="Te ayudaremos a Encontrar 'TU' Norte" 
                           FontSize="16" 
                           TextColor="#94A3B8"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Frame BackgroundColor="#1F2937" CornerRadius="15" HasShadow="True" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="¿Qué es el Proyecto?" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="White" />
                        <Label Text="Es una aplicación diseñada para ayudar a personas con problemas de orientación. Utiliza sensores del teléfono para detectar el norte y facilitar la navegación." 
                               FontSize="16" 
                               TextColor="#CBD5E1"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="#1F2937" CornerRadius="15" HasShadow="True" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Objetivo" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="White" />
                        <Label Text="Brindar una herramienta simple y accesible para mejorar la orientación y movilidad de los usuarios en su entorno." 
                               FontSize="16" 
                               TextColor="#CBD5E1"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Comenzar" 
                        Clicked="OnComenzarClicked"
                        Margin="0, 40, 0, 0"
                        BackgroundColor="#1F2937"
                        TextColor="White"
                        BorderColor="White"
                        BorderWidth="2"
                        CornerRadius="25"
                        HeightRequest="60"
                        WidthRequest="250"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>

                <Label Text="¿A dónde quieres ir?" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White"
                       HorizontalOptions="Center" 
                       Margin="0, 20, 0, 10"/>

                <Button Text="Ir de compras al jumbo" 
                        Clicked="OnCasaAbueloClicked"
                        Margin="0, 5, 0, 0"
                        BackgroundColor="#38BDF8"
                        TextColor="#0F172A"
                        CornerRadius="25"
                        HeightRequest="60"
                        WidthRequest="250"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>

                <Button Text="Ir a la Universidad" 
                        Clicked="OnUniversidadClicked"
                        Margin="0, 15, 0, 0"
                        BackgroundColor="#1F2937"
                        TextColor="White"
                        BorderColor="#38BDF8"
                        BorderWidth="2"
                        CornerRadius="25"
                        HeightRequest="60"
                        WidthRequest="250"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>

                <Label Text="Versión 1.0 - Proyecto educativo" 
                       FontSize="12" 
                       TextColor="#4B5563"
                       HorizontalOptions="Center" 
                       Margin="0, 30, 0, 40"/>

            </VerticalStackLayout>
        </ScrollView>

        <Border WidthRequest="70" 
                HeightRequest="70" 
                HorizontalOptions="Start" 
                VerticalOptions="End" 
                Margin="20"
                Stroke="#334155"
                StrokeThickness="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="35" />
            </Border.StrokeShape>
            <Image Source="logolobo.png" Aspect="AspectFill" />
        </Border>

    </Grid>
</ContentPage>