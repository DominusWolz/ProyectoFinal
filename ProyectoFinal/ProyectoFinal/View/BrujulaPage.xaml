<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.View.BrujulaPage"
             Title="Brújula"
             BackgroundColor="#0F172A"> <!-- Fondo azul oscuro para toda la página -->

    <!-- Grid principal que actúa como contenedor de todos los elementos -->
    <Grid>

        <!-- StackLayout vertical centrado que organiza todos los elementos de la brújula -->
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="35">

            <!-- Título principal de la página -->
            <Label Text="Brujula Magnetica" 
                   FontSize="22" 
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <!-- Label que muestra los grados actuales de orientación -->
            <!-- Se actualizará desde el código C# (x:Name permite referenciarlo) -->
            <Label x:Name="lblGrados" 
                   Text="0°" 
                   FontSize="56" 
                   FontAttributes="Bold" 
                   TextColor="#38BDF8" 
                   HorizontalOptions="Center"/>

            <!-- Grid que contiene el diseño visual de la brújula -->
            <Grid WidthRequest="300" HeightRequest="300" HorizontalOptions="Center">
                
                <!-- Círculo exterior de la brújula -->
                <Ellipse Fill="#1F2937" Stroke="#334155" StrokeThickness="10" />

                <!-- Puntos cardinales -->
                <!-- Norte en rojo (más destacado) -->
                <Label Text="N" TextColor="#EF4444" FontSize="26" FontAttributes="Bold" 
                       HorizontalOptions="Center" VerticalOptions="Start" Margin="0,15,0,0"/>
                
                <!-- Sur en gris -->
                <Label Text="S" TextColor="#94A3B8" FontSize="22" FontAttributes="Bold" 
                       HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,15"/>
                
                <!-- Este en gris -->
                <Label Text="E" TextColor="#94A3B8" FontSize="22" FontAttributes="Bold" 
                       HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,15,0"/>
                
                <!-- Oeste en gris (O en español, en lugar de W) -->
                <Label Text="O" TextColor="#94A3B8" FontSize="22" FontAttributes="Bold" 
                       HorizontalOptions="Start" VerticalOptions="Center" Margin="15,0,0,0"/>

                <!-- Contenedor de la aguja que se rotará según la orientación -->
                <!-- x:Name permite manipular la rotación desde código C# -->
                <Grid x:Name="ContenedorAguja" HorizontalOptions="Center" VerticalOptions="Center">
                    
                    <!-- StackLayout vertical que contiene las dos mitades de la aguja -->
                    <VerticalStackLayout Spacing="0">
                        
                        <!-- Mitad superior de la aguja (color rojo - apunta al Norte) -->
                        <!-- Triángulo con base inferior y punta superior -->
                        <Polygon Points="20,0 40,100 0,100" 
                                 Fill="#EF4444" HeightRequest="100" WidthRequest="40" />
                        
                        <!-- Mitad inferior de la aguja (color gris/blanco - apunta al Sur) -->
                        <!-- Triángulo invertido con base superior y punta inferior -->
                        <Polygon Points="0,0 40,0 20,100" 
                                 Fill="#E2E8F0" HeightRequest="100" WidthRequest="40" />
                    </VerticalStackLayout>
                    
                    <!-- Círculo central de la aguja (eje de rotación) -->
                    <Ellipse WidthRequest="20" HeightRequest="20" Fill="#38BDF8" 
                             HorizontalOptions="Center" VerticalOptions="Center" />
                </Grid>
            </Grid>

            <!-- Mensaje informativo para que el usuario calibre la brújula -->
            <Label Text="Mueve tu teléfono en forma de '8' para calibrar" 
                   FontSize="14" 
                   TextColor="#94A3B8"
                   HorizontalOptions="Center" />

            <!-- Botón para volver a la pantalla de inicio -->
            <Button Text="Volver al Inicio" 
                    Clicked="OnVolverClicked"  <!-- Evento que se manejará en C# -->
                    Margin="0, 10, 0, 0"
                    BackgroundColor="Transparent"
                    TextColor="#38BDF8"
                    BorderColor="#38BDF8"
                    BorderWidth="1"
                    CornerRadius="20"
                    HeightRequest="45"
                    WidthRequest="200"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Borde circular en la esquina superior derecha que contiene el logo -->
        <Border WidthRequest="70" 
                HeightRequest="70" 
                HorizontalOptions="End" 
                VerticalOptions="Start" 
                Margin="20"
                Stroke="#334155"
                StrokeThickness="2">
            
            <!-- Definición de la forma redondeada del borde -->
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="35" /> <!-- Radio 35 = círculo perfecto -->
            </Border.StrokeShape>
            
            <!-- Imagen del logo (se mantiene como aspecto fill) -->
            <Image Source="logolobo.png" Aspect="AspectFill" />
        </Border>

    </Grid>
</ContentPage>